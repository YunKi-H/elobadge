# Compose and Caddy
APP_DOMAIN=badge.example.com
CHESSBADGE_IMAGE=ghcr.io/yunki-h/chessbadge:latest

# Server runtime
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep escaped newlines on one line: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=

CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=
CHZZK_REDIRECT_URI=https://badge.example.com/api/auth/chzzk/callback
CHZZK_OPEN_API_BASE_URL=https://openapi.chzzk.naver.com
CHZZK_TOKEN_ENCRYPTION_KEY=

CHESS_COM_USER_AGENT=ChessBadge/0.1 (contact: your-email@example.com)
APP_SECRET=

# Optional comma-separated extra origins. APP_DOMAIN is allowed automatically.
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_MAX=300
