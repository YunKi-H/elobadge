NODE_ENV=development
PORT=3000
WEB_APP_URL=http://localhost:5173

# Firebase Admin SDK (Fastify server only)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Web SDK (values prefixed with VITE_ are visible in the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=
CHZZK_REDIRECT_URI=http://localhost:3000/api/auth/chzzk/callback
CHZZK_OPEN_API_BASE_URL=https://openapi.chzzk.naver.com
# Generate with: openssl rand -base64 32
CHZZK_TOKEN_ENCRYPTION_KEY=

# Chess.com asks PubAPI clients to identify the application and a contact.
CHESS_COM_USER_AGENT=ChessBadge/0.1 (contact: your-email@example.com)

LICHESS_CLIENT_ID=
LICHESS_REDIRECT_URI=http://localhost:3000/api/auth/lichess/callback

APP_SECRET=
