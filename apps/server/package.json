{
  "name": "@chessbadge/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @chessbadge/core build && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/auth/*.test.ts src/auth/chzzk/*.test.ts src/chess/*.test.ts src/chess/chesscom/*.test.ts src/chzzk/*.test.ts src/firebase/*.test.ts src/realtime/*.test.ts src/routes/*.test.ts src/security/*.test.ts",
    "test:emulator:run": "tsx --test src/firebase/emulator/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@chessbadge/core": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "fastify": "^5.10.0",
    "firebase-admin": "^14.1.0",
    "pino": "^10.3.1",
    "socket.io-client": "2.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
