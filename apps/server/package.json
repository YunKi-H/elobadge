{
  "name": "@chessbadge/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @chessbadge/core build && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/auth/*.test.ts src/auth/chzzk/*.test.ts src/chzzk/*.test.ts src/firebase/*.test.ts src/security/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@chessbadge/core": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.2.0",
    "fastify": "^5.4.0",
    "firebase-admin": "^14.1.0",
    "pino": "^9.7.0",
    "socket.io-client": "2.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "eslint": "^9.30.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
